{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${ConnectionStrings__DefaultConnection}",
    "RabbitMQ": "${ConnectionStrings__RabbitMQ}",
    "Redis": "${ConnectionStrings__Redis}"
  },
  "Redis": {
    "ConnectionString": "${Redis__ConnectionString}",
    "InstanceName": "quanghc-uat:",
    "DefaultTtl": 3600
  },
  "Jwt": {
    "Key": "${Jwt__Key}",
    "Issuer": "QuangHuongComputer",
    "Audience": "QuangHuongComputer",
    "ExpireMinutes": 60
  },
  "Features": {
    "UseRealPayment": true,
    "UseRealEmail": true,
    "UseMockData": false,
    "SandboxMode": true,
    "EnableDetailedErrors": false
  },
  "OAuth": {
    "Google": {
      "ClientId": "${OAuth__Google__ClientId}",
      "ClientSecret": "${OAuth__Google__ClientSecret}"
    },
    "Facebook": {
      "AppId": "${OAuth__Facebook__AppId}",
      "AppSecret": "${OAuth__Facebook__AppSecret}"
    }
  },
  "Payment": {
    "VNPay": {
      "TmnCode": "${Payment__VNPay__TmnCode}",
      "HashSecret": "${Payment__VNPay__HashSecret}",
      "PaymentUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
      "ReturnUrl": "${Payment__VNPay__ReturnUrl}",
      "Version": "2.1.0"
    },
    "Momo": {
      "PartnerCode": "${Payment__Momo__PartnerCode}",
      "AccessKey": "${Payment__Momo__AccessKey}",
      "SecretKey": "${Payment__Momo__SecretKey}",
      "Endpoint": "https://test-payment.momo.vn/v2/gateway/api/create",
      "ReturnUrl": "${Payment__Momo__ReturnUrl}",
      "NotifyUrl": "${Payment__Momo__NotifyUrl}"
    }
  },
  "Email": {
    "Smtp": {
      "Host": "${Email__Smtp__Host}",
      "Port": 587,
      "EnableSsl": true,
      "Username": "${Email__Smtp__Username}",
      "Password": "${Email__Smtp__Password}",
      "FromName": "Quang Huong Computer (UAT)",
      "FromEmail": "${Email__Smtp__FromEmail}"
    }
  },
  "Storage": {
    "CloudinaryUrl": "${Storage__CloudinaryUrl}",
    "LocalPath": "./uploads"
  },
  "AI": {
    "Gemini": {
      "ApiKey": "${AI__Gemini__ApiKey}",
      "Model": "gemini-pro"
    }
  },
  "Monitoring": {
    "EnableDetailedMetrics": true,
    "EnableTracing": true,
    "TracingSampleRate": 0.5
  },
  "Cors": {
    "AllowedOrigins": "${Cors__AllowedOrigins}"
  },
  "Frontend": {
    "Url": "${Frontend__Url}"
  },
  "AllowedHosts": "*"
}
