{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=quanghuongdb_test;Username=postgres;Password=${DB_PASSWORD};Timeout=30",
    "RabbitMQ": "amqp://guest:guest@localhost:5672",
    "Redis": "localhost:6379,password=${REDIS_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "QuangHuongComputer",
    "Audience": "QuangHuongComputer",
    "ExpireMinutes": 60
  },
  "Features": {
    "UseRealPayment": false,
    "UseRealEmail": false,
    "UseMockData": true,
    "EnableDetailedErrors": true
  },
  "Payment": {
    "VNPay": {
      "TmnCode": "DEMO",
      "HashSecret": "DEMOSECRET",
      "PaymentUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
      "ReturnUrl": "http://localhost:5173/payment/vnpay-return",
      "Version": "2.1.0"
    },
    "Momo": {
      "PartnerCode": "DEMO",
      "AccessKey": "DEMO",
      "SecretKey": "DEMO",
      "Endpoint": "https://test-payment.momo.vn/v2/gateway/api/create",
      "ReturnUrl": "http://localhost:5173/payment/momo-return",
      "NotifyUrl": "http://localhost:5000/api/payments/momo-ipn"
    }
  },
  "Email": {
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "EnableSsl": false,
      "Username": "",
      "Password": "",
      "FromName": "Test - Quang Huong Computer",
      "FromEmail": "test@quanghuongcomputer.local"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:5174"
    ]
  },
  "AllowedHosts": "*"
}
