{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=quanghuongdb;Username=postgres;Password=postgres123;Timeout=30",
    "RabbitMQ": "amqp://guest:guest@localhost:5672",
    "Redis": "localhost:6379,password=redis123"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=redis123",
    "InstanceName": "quanghc:",
    "DefaultTtl": 3600
  },
  "RabbitMQ": {
    "Host": "localhost"
  },
  "Jwt": {
    "Key": "quanghuong_secret_key_must_be_at_least_32_chars_long_for_hs256",
    "Issuer": "QuangHuongComputer",
    "Audience": "QuangHuongComputer",
    "ExpireMinutes": 60
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 60
  },
  "OAuth": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENT_ID}",
      "ClientSecret": "${GOOGLE_CLIENT_SECRET}"
    },
    "Facebook": {
      "AppId": "",
      "AppSecret": ""
    }
  },
  "Payment": {
    "VNPay": {
      "TmnCode": "${VNPAY_TMN_CODE}",
      "HashSecret": "${VNPAY_HASH_SECRET}",
      "PaymentUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
      "ReturnUrl": "http://localhost:5173/payment/vnpay-return",
      "Version": "2.1.0"
    },
    "Momo": {
      "PartnerCode": "${MOMO_PARTNER_CODE}",
      "AccessKey": "${MOMO_ACCESS_KEY}",
      "SecretKey": "${MOMO_SECRET_KEY}",
      "Endpoint": "https://test-payment.momo.vn/v2/gateway/api/create",
      "ReturnUrl": "http://localhost:5173/payment/momo-return",
      "NotifyUrl": "http://localhost:5000/api/payments/momo-ipn"
    },
    "ZaloPay": {
      "AppId": "${ZALOPAY_APP_ID}",
      "Key1": "${ZALOPAY_KEY1}",
      "Key2": "${ZALOPAY_KEY2}",
      "Endpoint": "https://sb-openapi.zalopay.vn/v2/create",
      "CallbackUrl": "http://localhost:5000/api/payments/zalopay-callback"
    },
    "SePay": {
      "ApiKey": "${SEPAY_API_KEY}",
      "AccountNumber": "${SEPAY_ACCOUNT_NUMBER}",
      "BankCode": "${SEPAY_BANK_CODE}"
    }
  },
  "Email": {
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "tungduongvbhp@gmail.com",
      "Password": "${SMTP_PASSWORD}",
      "FromName": "Quang Huong Computer",
      "FromEmail": "tungduongvbhp@gmail.com"
    }
  },
  "Sms": {
    "Twilio": {
      "AccountSid": "${TWILIO_ACCOUNT_SID}",
      "AuthToken": "${TWILIO_AUTH_TOKEN}",
      "PhoneNumber": "${TWILIO_PHONE_NUMBER}"
    }
  },
  "Storage": {
    "CloudinaryUrl": "${CLOUDINARY_URL}",
    "LocalPath": "./uploads"
  },
  "AI": {
    "OpenAI": {
      "ApiKey": "${OPENAI_API_KEY}",
      "Model": "gpt-3.5-turbo",
      "MaxTokens": 500
    },
    "Gemini": {
      "ApiKey": "${GEMINI_API_KEY}",
      "Model": "gemini-flash-latest"
    }
  },
  "SignalR": {
    "Enabled": true,
    "HubPath": "/hubs/chat"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "AllowedHosts": "*"
}