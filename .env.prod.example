# ===========================================
# Quang Huong Computer - Production Environment Variables
# ===========================================
# Copy this file to .env.prod and fill in REAL production values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ===========================================

# ================================
# Application Version
# ================================
APP_VERSION=latest

# ================================
# PostgreSQL (Production)
# ================================
POSTGRES_DB=quanghuongdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ================================
# Redis (Production)
# ================================
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ================================
# RabbitMQ (Production)
# ================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBIT_PASSWORD

# ================================
# JWT Authentication
# ================================
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_64_CHARS_RANDOM_STRING_FOR_PRODUCTION_JWT
JWT_EXPIRE_MINUTES=60

# ================================
# Domain Configuration
# ================================
PROD_DOMAIN=https://quanghuongcomputer.vn
PROD_DOMAIN_WWW=https://www.quanghuongcomputer.vn

# ================================
# Nginx Ports
# ================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ================================
# Frontend Build Variables
# ================================
VITE_API_URL=https://quanghuongcomputer.vn/api
VITE_NODE_ENV=production
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_VNPAY_RETURN_URL=https://quanghuongcomputer.vn/payment/vnpay-return
VITE_MOMO_RETURN_URL=https://quanghuongcomputer.vn/payment/momo-return
VITE_ZALOPAY_RETURN_URL=https://quanghuongcomputer.vn/payment/zalopay-return
VITE_SIGNALR_HUB_URL=https://quanghuongcomputer.vn/hubs/chat
VITE_SOCKET_URL=https://quanghuongcomputer.vn

# ================================
# OAuth
# ================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ================================
# Payment Gateways (PRODUCTION endpoints)
# ================================
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_PAYMENT_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_RETURN_URL=https://quanghuongcomputer.vn/payment/vnpay-return

MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=https://quanghuongcomputer.vn/payment/momo-return
MOMO_NOTIFY_URL=https://quanghuongcomputer.vn/api/payments/momo-ipn

ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_ENDPOINT=https://openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=https://quanghuongcomputer.vn/api/payments/zalopay-callback

SEPAY_API_KEY=your_sepay_api_key
SEPAY_ACCOUNT_NUMBER=your_sepay_account_number
SEPAY_BANK_CODE=your_sepay_bank_code

# ================================
# Email (SMTP)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=quanghuongvbhp@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=quanghuongvbhp@gmail.com

# ================================
# Cloud Storage
# ================================
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# ================================
# AI Services
# ================================
GEMINI_API_KEY=your_gemini_api_key
